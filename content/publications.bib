@article{zhang2025seeingeye,
  selected={true},
  title = {SeeingEye: Agentic Information Flow Unlocks Multimodal Reasoning In Text-only LLMs},
  author = {Weijia Zhang* and Zijia Liu* and Haoru Li* and Haoqi Chen* and Jiaxuan You},
  year = {2025},
  journal = {arXiv preprint},
  url = {https://arxiv.org/abs/2505.13508},
  abstract = {We present SeeingEye, an agent-based multimodal reasoning system that enables text-only LLMs to process and understand visual information through an innovative agentic information flow architecture. A 3B VLM translator generates Structured Intermediate Representations with position and confidence encodings, while an 8B text-only reasoner performs multi-step logic, outperforming 32B models on MMMU and MIA-Bench benchmarks.},
  description = {An agent-based framework that enables text-only LLMs to perform multimodal reasoning through agentic information flow architecture.},
  keywords = {Multimodal AI, Large Language Models, Agent Systems, Computer Vision}
}

@article{liu2025timer1,
  selected={true},
  title = {Time-R1: Towards Comprehensive Temporal Reasoning in LLMs},
  author = {Zijia Liu and Peixuan Han and Haofeng Yang and Haoru Li and Jiaxuan You},
  year = {2025},
  journal = {arXiv preprint},
  url = {https://arxiv.org/abs/2510.25092},
  abstract = {We present a comprehensive evaluation and training framework for improving temporal reasoning capabilities in large language models. We build evaluation pipelines to assess models including Deepseek-R1, Qwen, and LLaMA on event prediction tasks, and design a reinforcement learning training framework with three-stage curriculum and dynamic reward systems.},
  description = {A comprehensive evaluation and training framework for improving temporal reasoning capabilities in large language models.},
  keywords = {Temporal Reasoning, Large Language Models, Event Prediction, Benchmarking}
}

